generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id                 String   @id @default(cuid())
  nome               String
  email              String   @unique
  senha              String
  funcao             String
  setor              String
  empresaId          String
  empresasPermitidas Json?
  criadoEm           DateTime @default(now())
}

model Empresa {
  id        String   @id @default(cuid())
  nome      String
  logoUrl   String?
  criadoEm  DateTime @default(now())
}

model Documento {
  id                 String   @id @default(cuid())
  empresaId          String
  codigo             String
  titulo             String
  categoria          String
  setor              String
  autor              String
  dataEnvio          DateTime @default(now())
  dataAtualizacao    DateTime?
  dataVencimento     DateTime?
  arquivoUrl         String
  status             String
  revisao            Int      @default(1)
  motivoReprovacao   String?
  aprovadoPor        String?
  dataAprovacao      DateTime?
  dataObsoletado     DateTime?
  
  requisitos         DocumentoRequisito[]
  auditorias         AuditoriaDocumento[]
}

model Leitura {
  id              String   @id @default(cuid())
  empresaId       String
  usuarioId       String
  usuarioNome     String
  usuarioSetor    String
  documentoId     String
  documentoCodigo String
  documentoTitulo String
  documentoVersao String
  dataHoraLeitura DateTime @default(now())
}

model Notificacao {
  id        String   @id @default(cuid())
  empresaId String
  usuarioId String   // ID do usuário que recebe
  titulo    String
  mensagem  String
  lida      Boolean  @default(false)
  linkUrl   String?
  criadoEm  DateTime @default(now())
}

model RequisitoVigilancia {
  id          String   @id @default(cuid())
  empresaId   String
  norma       String   @default("RDC 978/2025")
  artigo      String
  descricao   String
  criadoEm    DateTime @default(now())
  
  documentos  DocumentoRequisito[]
}

model DocumentoRequisito {
  id            String   @id @default(cuid())
  requisitoId   String
  documentoId   String
  
  requisito     RequisitoVigilancia @relation(fields: [requisitoId], references: [id], onDelete: Cascade)
  documento     Documento           @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  
  @@unique([requisitoId, documentoId])
}

// ============================================================================
// NOVO SISTEMA DE AUDITORIA E CONFORMIDADE (RDC 978 / SGQ Avançado)
// ============================================================================

model RdcItem {
  id                String   @id @default(cuid())
  referencia        String   // Ex: Art.2-I
  capitulo          String?
  secao             String?
  subsecao          String?
  artigo            String?
  paragrafo         String?
  inciso            String?
  alinea            String?
  tipo              String?  // Ex: Artigo, Inciso, Alínea, §1º
  textoIntegral     String   // Texto completo da norma
  requisitoObjetivo String?  // Requisito transformado (O estabelecimento possui...)
  evidenciaObjetiva String?  // Ex: POP vigente, Planilha, Certidão
  categoria         String?  // Ex: Licenciamento, Gestão da Qualidade
  setor             String?  // Setor responsável sugerido
  tipoDocumento     String?  // PDF, Imagem, Planilha, etc.
  criticidade       String?  // Baixo, Médio, Alto, Crítico
  aplicabilidade    String?  // Ex: Tipo I, Tipo II, Central, Itinerante

  auditorias        AuditoriaRdc[]
}

model AuditoriaRdc {
  id                  String   @id @default(cuid())
  empresaId           String
  rdcItemId           String
  conforme            String?  // S (Sim), N (Não), NA (Não Aplicável)
  evidenciaEncontrada String?  
  acaoCorretiva       String?
  responsavelId       String?
  prazo               DateTime?
  status              String   @default("Pendente") // Pendente, Em Andamento, Concluído
  observacoes         String?
  atualizadoEm        DateTime @updatedAt

  rdcItem             RdcItem       @relation(fields: [rdcItemId], references: [id], onDelete: Cascade)
  planosAcao          PlanoAcao5W2H[]
  documentos          AuditoriaDocumento[]

  @@unique([empresaId, rdcItemId])
}

model AuditoriaDocumento {
  id             String   @id @default(cuid())
  auditoriaId    String
  documentoId    String
  criadoEm       DateTime @default(now())
  
  auditoria      AuditoriaRdc @relation(fields: [auditoriaId], references: [id], onDelete: Cascade)
  documento      Documento    @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@unique([auditoriaId, documentoId])
}

model PlanoAcao5W2H {
  id                String   @id @default(cuid())
  auditoriaRdcId    String?
  naoConformidadeId String?
  what            String?  // O que será feito?
  why             String?  // Por que será feito?
  where           String?  // Onde será feito?
  when            DateTime?// Quando será feito?
  who             String?  // Quem fará?
  how             String?  // Como será feito?
  howMuch         String?  // Quanto custará?
  status          String   @default("Pendente")
  criadoEm        DateTime @default(now())

  auditoriaRdc    AuditoriaRdc?    @relation(fields: [auditoriaRdcId], references: [id], onDelete: Cascade)
  naoConformidade NaoConformidade? @relation(fields: [naoConformidadeId], references: [id], onDelete: Cascade)
}

// ============================================================================
// NOVO SISTEMA DE GESTÃO DA QUALIDADE (Não Conformidades)
// ============================================================================

model NaoConformidade {
  id                String   @id @default(cuid())
  empresaId         String
  titulo            String
  descricao         String
  origem            String   // Ex: Auditoria Interna, Auditoria Externa, Reclamação, Melhoria
  tipo              String?  // Não Conformidade, Desvio, Observação
  setor             String?  // Setor relacionado
  criticidade       String?  // Alta, Média, Baixa
  dataRegistro      DateTime @default(now())
  
  // Análise e Causa
  analiseCausa      String?
  
  // Ações Corretivas/Melhoria
  acaoCorretiva     String?
  responsavelAcao   String?
  prazoAcao         DateTime?
  
  // Monitoramento
  status            String   @default("Registrada") // Registrada, Em Análise, Ação Pendente, Concluída
  dataFechamento    DateTime?
  observacoesFinais String?
  
  criadoPor         String   // Nome ou ID do usuário que criou
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt
  
  analises          AnaliseCausa[]
  planosAcao        PlanoAcao5W2H[]
}

model AnaliseCausa {
  id                String   @id @default(cuid())
  naoConformidadeId String
  metodologia       String   // Ishikawa, 5Porques, FMEA, Brainstorming
  status            String   @default("Em Andamento") // Em Andamento, Concluída, Rejeitada
  dadosJson         String   @db.Text // JSON estruturado armazenado como string para maior portabilidade e evitar problemas de migração no Prisma com Json nativo dependendo do banco
  rpnCalculado      Int?     // Para métricas rápidas de FMEA
  
  // Rastreabilidade e Auditoria
  criadoPor         String
  atualizadoPor     String?
  aprovadoPor       String?
  dataCriacao       DateTime @default(now())
  dataAtualizacao   DateTime @updatedAt
  dataAprovacao     DateTime?

  // Relações
  sugestoesIA       LogSugestaoIA[]
  naoConformidade   NaoConformidade @relation(fields: [naoConformidadeId], references: [id], onDelete: Cascade)
}

model LogSugestaoIA {
  id              String   @id @default(cuid())
  analiseCausaId  String
  tipo            String   // Preenchimento de 5 Porques, Ishikawa, Resumo, etc.
  conteudoSugerido String   @db.Text // JSON estruturado da sugestão
  statusAprovacao String   // Aceito, Editado, Rejeitado
  usuarioId       String
  dataAcao        DateTime @default(now())
  
  analiseCausa    AnaliseCausa @relation(fields: [analiseCausaId], references: [id], onDelete: Cascade)
}
