generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senha     String
  funcao    String
  setor     String
  empresaId String
  criadoEm  DateTime @default(now())
}

model Documento {
  id                 String   @id @default(cuid())
  empresaId          String
  codigo             String
  titulo             String
  categoria          String
  setor              String
  autor              String
  dataEnvio          DateTime @default(now())
  dataAtualizacao    DateTime?
  dataVencimento     DateTime?
  arquivoUrl         String
  status             String
  revisao            Int      @default(1)
  motivoReprovacao   String?
  aprovadoPor        String?
  dataAprovacao      DateTime?
  dataObsoletado     DateTime?
}

model Leitura {
  id              String   @id @default(cuid())
  empresaId       String
  usuarioId       String
  usuarioNome     String
  usuarioSetor    String
  documentoId     String
  documentoCodigo String
  documentoTitulo String
  documentoVersao String
  dataHoraLeitura DateTime @default(now())
}
