generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senha     String
  funcao    String
  setor     String
  empresaId String
  criadoEm  DateTime @default(now())
}

model Documento {
  id                 String   @id @default(cuid())
  empresaId          String
  codigo             String
  titulo             String
  categoria          String
  setor              String
  autor              String
  dataEnvio          DateTime @default(now())
  dataAtualizacao    DateTime?
  dataVencimento     DateTime?
  arquivoUrl         String
  status             String
  revisao            Int      @default(1)
  motivoReprovacao   String?
  aprovadoPor        String?
  dataAprovacao      DateTime?
  dataObsoletado     DateTime?
  
  requisitos         DocumentoRequisito[]
}

model Leitura {
  id              String   @id @default(cuid())
  empresaId       String
  usuarioId       String
  usuarioNome     String
  usuarioSetor    String
  documentoId     String
  documentoCodigo String
  documentoTitulo String
  documentoVersao String
  dataHoraLeitura DateTime @default(now())
}

model Notificacao {
  id        String   @id @default(cuid())
  empresaId String
  usuarioId String   // ID do usuário que recebe
  titulo    String
  mensagem  String
  lida      Boolean  @default(false)
  linkUrl   String?
  criadoEm  DateTime @default(now())
}

model RequisitoVigilancia {
  id          String   @id @default(cuid())
  empresaId   String
  norma       String   @default("RDC 978/2025")
  artigo      String
  descricao   String
  criadoEm    DateTime @default(now())
  
  documentos  DocumentoRequisito[]
}

model DocumentoRequisito {
  id            String   @id @default(cuid())
  requisitoId   String
  documentoId   String
  
  requisito     RequisitoVigilancia @relation(fields: [requisitoId], references: [id], onDelete: Cascade)
  documento     Documento           @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  
  @@unique([requisitoId, documentoId])
}
